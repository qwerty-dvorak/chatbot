DJANGO_SETTINGS_MODULE=config.settings.local
SECRET_KEY=change-me
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

POSTGRES_DB=chatbot
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=chatbot
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

MEDIA_ROOT=./media
STATIC_ROOT=./staticfiles

# Chat model endpoint (vLLM or OpenAI-compatible server)
CHAT_BASE_URL=http://localhost:9000/v1
CHAT_API_KEY=local-placeholder

# Embedding model endpoint (separate vLLM instance or same server)
EMBEDDING_BASE_URL=http://localhost:9001/v1
EMBEDDING_API_KEY=local-placeholder

# Reranker endpoint (can share the embedding server)
RERANKER_BASE_URL=http://localhost:9001/v1
RERANKER_API_KEY=local-placeholder

# Model names must use the openai/ prefix when pointing at a custom vLLM/OpenAI-compatible endpoint.
# Example: openai/gemma-4-26b-a4b-it
CHAT_MODEL=openai/gemma-4-26b-a4b-it
VISION_MODEL=openai/gemma-4-26b-a4b-it

# Text embedding: nvidia/llama-embed-nemotron-8b (dim: 4096)
TEXT_EMBEDDING_MODEL=openai/nvidia/llama-embed-nemotron-8b
TEXT_EMBEDDING_DIM=4096

# Multimodal embedding: nvidia/nemotron-colembed-vl-8b-v2 (dim: 4096)
MULTIMODAL_EMBEDDING_MODEL=nvidia/nemotron-colembed-vl-8b-v2
MULTIMODAL_EMBEDDING_DIM=4096

# Reranker: Qwen3-VL-Reranker-8B
RERANKER_MODEL=Qwen/Qwen3-VL-Reranker-8B

# Milvus vector store
MILVUS_HOST=localhost
MILVUS_PORT=19530

CHAT_CONTEXT_MAX_TOKENS=32000
CHAT_CONTEXT_MAX_TOKENS_LARGE=256000
CHAT_RESPONSE_MAX_TOKENS=4096
CHAT_COMPACTION_THRESHOLD_TOKENS=14000
CHAT_STREAMING_ENABLED=true

# RAG feature flag — set to false to disable retrieval-augmented generation
RAG_ENABLED=true
RAG_TOP_K=8
RAG_MIN_SIMILARITY=0.45
RAG_CHUNK_TARGET_TOKENS=700
RAG_CHUNK_OVERLAP_TOKENS=120

MAX_UPLOAD_MB=50
INGESTION_SYNC=false
KNOWLEDGE_DEFAULT_VISIBILITY=private
MEMORY_AUTO_SAVE_DEFAULT=true

TOOL_CALLS_ENABLED=true
TOOL_CALL_TIMEOUT_SECONDS=60
TOOL_RESULT_MAX_TOKENS=4000
